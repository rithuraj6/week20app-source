

pipeline {
    agent any

    tools {
        maven 'Maven'
    }

    stages {

        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Unit Tests') {
            steps {
                sh 'mvn test'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                script {
                    def scannerHome = tool 'sonar-scanner'

                    withSonarQubeEnv('sonar-server') {
                        sh """
                        mvn sonar:sonar \
                        -Dsonar.projectKey=week20app \
                        -Dsonar.projectName=week20app
                        """
                    }
                }
            }
        }
        stage('Quallity Gate') {
            steps {
                timeout(time: 2, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }


        stage('OWASP Scan') {
            steps {
                sh '''
                dependency-check.sh \
                --scan . \
                --format HTML \
                --out reports || true
                '''
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                docker build \
                -t week20app:latest \
                .
                '''
            }
        }

        stage('Trivy Scan') {
            steps {
                sh '''
                mkdir -p trivy-reports

                trivy image \
                --format template \
                --template "@contrib/html.tpl" \
                -o trivy-reports/trivy-report.html \
                week20app:latest
                '''
            }
        }

        





    }










    post {
            always {
                archiveArtifacts artifacts: 'reports/*', allowEmptyArchive: true
            }
        }
}