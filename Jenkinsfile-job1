

pipeline {
    agent any

    tools {
        maven 'Maven'
    }

    stages {

        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Unit Tests') {
            steps {
                sh 'mvn test'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                script {
                    def scannerHome = tool 'sonar-scanner'

                    withSonarQubeEnv('sonar-server') {
                        sh """
                        mvn sonar:sonar \
                        -Dsonar.projectKey=week20app \
                        -Dsonar.projectName=week20app
                        """
                    }
                }
            }
        }
        stage('Quallity Gate') {
            steps {
                timeout(time: 2, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }


        stage('OWASP Scan') {
            steps {
                sh '''
                dependency-check.sh \
                --scan . \
                --format HTML \
                --out reports || true
                '''
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                docker build \
                -t week20app:latest \
                .
                '''
            }
        }

        stage('Trivy Scan') {
            steps {
                sh '''
                mkdir -p trivy-reports

                trivy image \
                -f table \
                -o trivy-reports/trivy-report.txt \
                week20app:latest
                '''
            }
        }


        stage('Docker Push') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'rithuraj6-dockerhub',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )
                ]) {
                    sh '''
                    echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin

                    docker tag week20app:latest rithuraj6/week20app:${BUILD_NUMBER}

                    docker push rithuraj6/week20app:${BUILD_NUMBER}
                    '''
                }
            }
        }

        stage('Update Helm Repo') {
            steps {

                sshagent(credentials: ['github-ssh']) {

                    sh '''
                    rm -rf helm-repo

                    git clone git@github.com:rithuraj6/week20app-helmchart.git helm-repo

                    cd helm-repo

                    sed -i 's/tag: ".*"/tag: "'"${BUILD_NUMBER}"'"/' values-dev.yaml

                    git config user.email "jenkins@local"
                    git config user.name "Jenkins"

                    git add values-dev.yaml

                    git commit -m "Update dev image to ${BUILD_NUMBER}" || true

                    git push origin main
                    '''
                }
            }
        }








        





    }
    






    post {
            always {
                archiveArtifacts artifacts: 'reports/*,trivy-reports/*', allowEmptyArchive: true
            }
        }

}
